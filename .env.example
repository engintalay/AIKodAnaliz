# ============================================================
# AIKodAnaliz - Yapılandırma Şablonu (.env.example)
# Bu dosyayı kopyalayıp .env olarak kaydedin:
#   cp .env.example .env
# ============================================================

# ---- Uygulama ----
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
SECRET_KEY=BURAYA-GUCLU-BIR-SIFRE-GIRIN

# ---- LM Studio ----
LMSTUDIO_HOST=localhost
LMSTUDIO_PORT=1234
LMSTUDIO_DEFAULT_MODEL=local-model
LMSTUDIO_MAX_TOKENS=5000
LMSTUDIO_TEMPERATURE=0.3
LMSTUDIO_TOP_P=0.9

# ---- Veritabanı ----
DB_CONNECTION_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aikodanaliz
DB_USER=admin
DB_PASSWORD=

# ---- Admin ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=BURAYA-GUCLU-BIR-SIFRE-GIRIN

# ---- Proje Limitleri ----
MAX_PROJECT_SIZE_MB=100
CONTEXT_LIMIT_TOKENS=4000
